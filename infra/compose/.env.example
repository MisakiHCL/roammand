SIGNALING_MAX_CONNECTIONS=1024
SIGNALING_MAX_CONNECTIONS_PER_IP=64
SIGNALING_MAX_RENDEZVOUS=4096
SIGNALING_MAX_RENDEZVOUS_PER_HOST=4
