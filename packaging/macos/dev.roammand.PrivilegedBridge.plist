<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>dev.roammand.PrivilegedBridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Library/PrivilegedHelperTools/roammand-privileged-bridge</string>
    <string>macos-daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>/var/log/roammand-privileged-bridge.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/roammand-privileged-bridge.log</string>
</dict>
</plist>
